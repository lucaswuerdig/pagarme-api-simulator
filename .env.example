# Fake Pagar.me API — environment variables
#
# Copy to `.env` for local dev, or set these in the Vercel project settings for
# the deployed function (ADR-006). Build and the test suite need none of these:
# they default to the in-memory store.

# Store backend selector. "kv" selects Vercel KV (Upstash Redis); any other
# value — including the default when unset — uses the in-memory store.
# Set STORE_BACKEND=kv on Vercel so lifecycle state survives stateless
# invocations. Leave unset locally / in CI.
STORE_BACKEND=kv

# Vercel KV (Upstash Redis) REST credentials. REQUIRED when STORE_BACKEND=kv —
# `createStore` throws at startup if either is missing. Provisioned by the
# Vercel KV integration in the Vercel project.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Local HTTP listen port for `npm run dev` / `npm start` (default 8088).
# Platform-managed on Vercel; not needed there.
PORT=8088
